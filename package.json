{
  "name": "empathetic-llms-user-study",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "worker:check": "tsc -p tsconfig.worker.json",
    "worker:dev": "pnpm dlx wrangler@latest dev --config wrangler.jsonc",
    "worker:deploy": "pnpm dlx wrangler@latest deploy --config wrangler.jsonc",
    "worker:deploy:admin": "pnpm dlx wrangler@latest deploy --config wrangler.admin.jsonc",
    "db:migrate:prod": "pnpm dlx wrangler@latest d1 migrations apply empathetic-study-prod --remote --config wrangler.jsonc",
    "db:migrate:test": "pnpm dlx wrangler@latest d1 migrations apply empathetic-study-test --remote --config wrangler.jsonc",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm lint && pnpm test && pnpm build && pnpm worker:check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/radio-canada-big": "^5.2.7",
    "@fontsource/source-serif-pro": "^5.2.5",
    "@hookform/resolvers": "^5.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
